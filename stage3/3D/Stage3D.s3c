        (if (=== (. node tag) 'for-in')
          (return (object (node node) (tag 'for-in-stmt') (name (. node name)) ("object" (lowerExpr (. node "object"))) (body ((. (. node body) map) lowerStmt)))))
        (if (=== (. node tag) 'for-of')
