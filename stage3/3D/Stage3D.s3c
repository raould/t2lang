    (lowerLetStar
      (lambda ((node))
        (let* ((stmts (array)))
          ((. (. node bindings) forEach) (lambda ((b))
            ((. stmts push) (object (node node) (tag 'let-stmt') (name (. b name)) (typeAnnotation (ternary (. b typeAnnotation) (lowerTypeExpr (. b typeAnnotation)) undefined)) (init (cond (. b init) (lowerExpr (. b init)) :else undefined))))))
