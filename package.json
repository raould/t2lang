{
    "name": "t2lang",
    "version": "0.1.0",
    "license": "CC0-1.0",
    "workspaces": [
        "t2lang-runtime"
    ],
    "bin": {
        "t2tc": "./bin/t2tc.cjs",
        "t2jc": "./bin/t2jc.cjs",
        "t2run": "./bin/t2run.cjs"
    },
    "files": [
        "bin/**",
        "phaseB/dist/**",
        "phaseB/package.json",
        "README.md",
        "LICENSE"
    ],
    "scripts": {
        "build": "npm --prefix phaseB run build",
        "prepare": "npm --prefix phaseB run build",
        "prepack": "npm --prefix phaseB run build",
        "test": "npm --prefix phaseA test && npm --prefix phaseB test",
        "lint": "npm --prefix phaseA run lint && npm --prefix phaseB run lint",
        "t2tc": "npm --prefix phaseB run phaseb --",
        "t2js": "npm --prefix phaseB run phaseb --",
        "t2run": "npm --prefix phaseB run phaseb --"
    },
    "dependencies": {
        "ohm-js": "^17.3.0"
    }
}
