(program
  (import (object (:named (array (object (:name "CharStream")) (object (:name "CommonTokenStream"))))) "antlr4ng")
  (import (object (:named (array (object (:name "Stage6Lexer"))))) "./Stage6Lexer")
  (import (object (:named (array (object (:name "Stage6Parser"))))) "./Stage6Parser")
  (import (object (:default "fs")) "node:fs")
  (import (object (:named (array (object (:name "astTopLevel"))))) "./Stage6-ast")
  (import (object (:named (array (object (:name "lowerTopLevel"))))) "./Stage6-lower")
  (import (object (:named (array (object (:name "emitTopLevel"))))) "./Stage6-codegen")
  (import (object (:named (array (object (:name "makeMacroEnv")) (object (:name "registerTopLevelNode"))))) "./Stage6-macro-env")
  (import (object (:named (array (object (:name "expandTopLevel")) (object (:name "formatExpansionErrors"))))) "./Stage6-macro-expand")
  (import (object (:named (array (object (:name "resolveTopLevel")) (object (:name "addBinding"))))) "./Stage6-scope-resolve")
  (import (object (:named (array (object (:name "resetSpans"))))) "./Stage6-spans")

  ;; ========== main ==========
  (const main
    (lambda ()
      (let* ((filePath (index (. process argv) 2))
             (input ((. fs readFileSync) (ternary (=== filePath '-') 0 filePath) 'utf-8'))
             (inputStream ((. CharStream fromString) input))
             (lexer (new Stage6Lexer inputStream))
             (tokenStream (new CommonTokenStream lexer))
             (parser (new Stage6Parser tokenStream))
             (tree ((. parser "program")))
             ;; Reset span table before each compilation unit
             (_spans (resetSpans (ternary (=== filePath '-') '<stdin>' filePath)))
             (macroEnv (makeMacroEnv)))
        ;; Streaming loop: process one top-level form at a time.
        ;; chain threads accumulated binding state across forms.
        (let* ((chain (array)))
          ((. ((. tree topLevel)) forEach)
            (lambda ((ctx))
              ;; Phase 0+1: parse and desugar one form at a time
              (let* ((surfaceNode (astTopLevel ctx)))
                ;; Phase 2: register then expand against incrementally-built macroEnv
                (registerTopLevelNode surfaceNode macroEnv)
                (let* ((expandedNode (expandTopLevel surfaceNode macroEnv)))
                  (if (> (. (. macroEnv errors) length) 0)
                    (begin
                      ((. console error) (formatExpansionErrors (. macroEnv errors)))
                      ((. process exit) 1)))
                  ;; Phase 3: resolve, lower, emit — one form at a time
                  (let* ((resolvedNode (resolveTopLevel expandedNode chain)))
                    (if (|| (=== (. resolvedNode tag) 'let-decl') (=== (. resolvedNode tag) 'const-decl'))
                      (set! chain (addBinding chain (. resolvedNode name) (new Set))))
                    (let* ((loweredNode (lowerTopLevel resolvedNode))
                           (emittedStr (emitTopLevel loweredNode)))
                      ((. (. process stdout) write) (+ emittedStr '\n'))))))))))))

  (main)
)
