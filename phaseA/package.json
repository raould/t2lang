{
  "name": "phaseA",
  "version": "0.1.0",
  "type": "module",
  "bin": {
    "t2tc": "./dist/cli.js",
    "t2jc": "./dist/cli.js",
    "t2run": "./dist/cli.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./api": {
      "import": "./dist/api.js",
      "types": "./dist/api.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "clean": "npm run clean-examples; rimraf dist",
    "clean-examples": "rimraf --glob examples/**/*.ts",
    "test": "npm run build && node ./scripts/run-tests.mjs",
    "lint": "eslint . --ext .ts",
    "prepublishOnly": "npm run build",
    "run-examples": "npm run build && node ./scripts/run-examples.mjs"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/node": "^22.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "commander": "^11.1.0",
    "eslint": "^9.0.0",
    "globals": "^15.0.0",
    "prettier": "^3.8.0",
    "rimraf": "^6.1.2",
    "tsx": "^4.21.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.53.0"
  }
}
